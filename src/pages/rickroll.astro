---
import DefaultLayout from '../layouts/DefaultLayout.astro';
import rickroll from '../assets/rickrolled.gif';
---

<DefaultLayout
  title='Never Gonna Give You Up'
  description='You just got rickrolled 🎵'
>
  <div
    class='flex flex-col items-center justify-center min-h-[70vh] gap-6 text-center px-4'
  >
    <h1 class='mt-2 text-4xl font-bold tracking-tight text-gray-900'>
      Never gonna give you up 🎵
    </h1>
    <p class='text-lg text-gray-500'>Te lo mereces por hacer clic aquí.</p>
    <img
      src={rickroll.src}
      alt='Rick Astley never gonna give you up'
      class='rounded-2xl shadow-xl max-w-sm w-full'
    />
    <p class='text-sm text-gray-400 italic'>We're no strangers to love...</p>
    <a
      href='/'
      class='my-8 text-sm text-indigo-600 hover:text-indigo-500 underline'
    >
      Volver al inicio (si te atreves)
    </a>
  </div>
</DefaultLayout>
